# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_hotspot

# OpenAI
OPENAI_API_KEY=sk-your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Tools (可选)
GITHUB_API_TOKEN=  # 可选，提高 GitHub API 限流额度
TOOL_TIMEOUT_SECONDS=30
TOOL_MAX_RETRIES=3
ARXIV_MAX_RESULTS=10
HUGGINGFACE_MAX_RESULTS=10

# App
APP_ENV=development
APP_DEBUG=true
